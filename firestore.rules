rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: anyone signed in can read; only owner can write
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // Rooms: anyone signed in can read; authenticated users can create;
    //        only host (or Cloud Functions via Admin SDK) can update
    match /rooms/{roomId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.status == "waiting"
        && request.resource.data.players.size() == 1
        && request.resource.data.players[0].uid == request.auth.uid;

      // Anyone in the room can update (join), but cannot change hostUid or gameType
      allow update: if request.auth != null
        && resource.data.status == "waiting"
        && request.resource.data.hostUid == resource.data.hostUid
        && request.resource.data.gameType == resource.data.gameType
        && (
          // Host can start game or modify settings
          request.auth.uid == resource.data.hostUid
          ||
          // Players can join (add themselves to players array)
          (
            request.resource.data.players.size() == resource.data.players.size() + 1
            && request.resource.data.status == "waiting"
          )
        );

      allow delete: if false;
    }

    // Game results: readable by participants; written only by Cloud Functions
    match /gameResults/{roomId} {
      allow read: if request.auth != null;
      allow write: if false; // Cloud Functions use Admin SDK (bypasses rules)
    }
  }
}
